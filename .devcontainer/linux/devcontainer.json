{
  "name": "PX4 (Linux Native)",
  "image": "ghcr.io/saltywriter38/docker-new/dev-env:latest",
  "remoteUser": "developer",
  "workspaceFolder": "/home/developer/workspace",
  "mounts": [
    "source=${localWorkspaceFolder},target=/home/developer/workspace,type=bind",

    // X11 Socket for GUI forwarding
    "source=/tmp/.X11-unix,target=/tmp/.X11-unix,type=bind",
    // Optional: Map GPU DRI devices (Redundant if using --device in runArgs, but safe)
    "source=/dev/dri,target=/dev/dri,type=bind"
  ],
  "containerEnv": {
    "DISPLAY": "${localEnv:DISPLAY}",
    "NVIDIA_VISIBLE_DEVICES": "all",
    "NVIDIA_DRIVER_CAPABILITIES": "all",
    "QT_X11_NO_MITSHM": "1"
  },
  "runArgs": [
    "--privileged",
    "--net=host",
    "--gpus=all",
    "--device=/dev/dri:/dev/dri",
    "--ipc=host",
    "--env", "NVIDIA_VISIBLE_DEVICES=all",
    "--env", "NVIDIA_DRIVER_CAPABILITIES=all",
    "--add-host=host.docker.internal:host-gateway",
    "-p", "127.0.0.1:9091:9091"
  ],
  "postCreateCommand": "bash /home/developer/scripts/postCreation.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools-extension-pack",
        "ms-vscode.cmake-tools",
        "ms-python.python",
        "VisualStudioExptTeam.vscodeintellicode"
      ]
    }
  }
}
